# MongoDB
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/portfolio?retryWrites=true&w=majority

# Server
PORT=5000
NODE_ENV=development

# CORS - your deployed frontend URL
CLIENT_URL=http://localhost:5173

# Nodemailer (Gmail example - use an App Password, not your real password)
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-16-char-app-password
EMAIL_TO=your-email@gmail.com

# Rate limit (contact form abuse prevention)
CONTACT_RATE_LIMIT_MAX=5
